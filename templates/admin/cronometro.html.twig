{% extends '@EasyAdmin/layout.html.twig' %}

{% block head_javascript %}
    {{ parent() }}

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/easytimer.js@4.4.0/dist/easytimer.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/moment@2.29.4/moment.min.js"></script>

    <style>
        body {
            background: #0b0b0b;
        }

        /* -----------------------------
            SELECT Y CONTADOR SUPERIOR
        ------------------------------*/
        .top-section {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            margin-bottom: 25px;
            flex-wrap: wrap;
        }

        .pilot-select {
            width: 300px;
        }

        .contador-box {
            background: #1e1e1e;
            padding: 12px 20px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 15px;
            color: white;
            font-weight: bold;
        }

        .contador-btn {
            width: 40px;
            height: 40px;
            border: none;
            border-radius: 10px;
            background: #2e86ff;
            color: white;
            font-size: 20px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        .contador-btn:hover {
            background: #1d6fe5;
        }

        /* -----------------------------
            GRID DE CRONOMETROS
        ------------------------------*/
        .chrono-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        @media(max-width: 768px) {
            .chrono-grid {
                grid-template-columns: 1fr;
            }
        }

        /* -----------------------------
            TARJETA GENERAL
        ------------------------------*/
        .chrono-card {
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0px 4px 20px rgba(0,0,0,0.3);
        }

        .chrono-label {
            font-size: 16px;
            font-weight: bold;
            text-transform: uppercase;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        .chrono-display {
            font-family: 'Courier New', monospace;
            font-size: 42px;
            font-weight: bold;
            text-align: center;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 15px;
        }

        /* -----------------------------
            BOTONES
        ------------------------------*/
        .chrono-buttons {
            display: flex;
            gap: 12px;
        }

        .btn-chrono {
            flex: 1;
            border: none;
            padding: 12px;
            border-radius: 10px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        .btn-start:hover {
            transform: scale(1.03);
        }

        .btn-stop {
            opacity: 0.9;
        }

        .btn-stop:hover {
            opacity: 1;
        }

        /* -----------------------------
            COLORES DE TARJETAS
        ------------------------------*/

        /* META */
        .c-meta {
            background: #0F6E56;
        }

        .c-meta .chrono-label {
            color: #ffffff;
        }

        .c-meta .chrono-display {
            background: #0b5643;
            color: white;
        }

        .c-meta .btn-start {
            background: #1fc98a;
            color: white;
        }

        .c-meta .btn-stop {
            background: #094336;
            color: white;
        }

        /* PITS */
        .c-pits {
            background: #8b5700;
        }

        .c-pits .chrono-label {
            color: #fdfdfd;
        }

        .c-pits .chrono-display {
            background: #6a4100;
            color: white;
        }

        .c-pits .btn-start {
            background: #f0a500;
            color: black;
        }

        .c-pits .btn-stop {
            background: #5a3500;
            color: white;
        }

        /* CAMBIO */
        .c-cambio {
            background: #165ca8;
        }

        .c-cambio .chrono-label {
            color: #ebebeb;
        }

        .c-cambio .chrono-display {
            background: #0e4785;
            color: white;
        }

        .c-cambio .btn-start {
            background: #3d95ff;
            color: white;
        }

        .c-cambio .btn-stop {
            background: #08376b;
            color: white;
        }

        /* DAÑOS */
        .c-danos {
            background: #a82222;
        }

        .c-danos .chrono-label {
            color: #fdfdfd;
        }

        .c-danos .chrono-display {
            background: #7e1515;
            color: white;
        }

        .c-danos .btn-start {
            background: #ff4f4f;
            color: white;
        }

        .c-danos .btn-stop {
            background: #5e0d0d;
            color: white;
        }
    </style>
{% endblock %}


{% block main %}

<div class="top-section">

    <!-- TIEMPO TOTAL ARRIBA -->
    <div style="width:100%; display:flex; justify-content:center; margin-bottom:20px;">
        <div class="contador-box">
            <span id="tiempoCarrera">
                ⏱ Carrera: 00:00:00
            </span>
        </div>
    </div>

    <!-- PILOTO ACTUAL -->
    <div class="pilot-select">
        <label style="color:white; font-weight:bold; margin-bottom:5px; display:block;">
            Piloto actual
        </label>

        <select class="form-select" id="pilotoActual">
            <option selected>Seleccionar piloto</option>

            {% for p in pilotos %}
                <option value="{{ p.id }}">
                    {{ p.nombre }}
                </option>
            {% endfor %}
        </select>
    </div>


    <!-- SIGUIENTE PILOTO -->
    <div class="pilot-select">
        <label style="color:white; font-weight:bold; margin-bottom:5px; display:block;">
            Siguiente piloto
        </label>

        <select class="form-select" id="siguientePiloto">
            <option selected>Seleccionar siguiente piloto</option>

            {% for p in pilotos %}
                <option value="{{ p.id }}">
                    {{ p.nombre }}
                </option>
            {% endfor %}
        </select>
    </div>


    <!-- VUELTAS -->
    <div class="contador-box">
        <span id="labelContador">
            Vuelta actual: 1
        </span>
    </div>


    <!-- FINALIZAR EVENTO -->
    <div class="contador-box">
        <button
            onclick="finalizarEvento()"
            style="
                background:#ff4d4d;
                border:none;
                color:white;
                padding:10px 20px;
                border-radius:10px;
                font-weight:bold;
                cursor:pointer;
            "
        >
            Finalizar evento
        </button>
    </div>

</div>


<div class="chrono-grid">

    <!-- META -->
    <div class="chrono-card c-meta">
        <div class="chrono-label">🏁 META → META</div>
        <div class="chrono-display" id="chronoMeta">00:00:00</div>

        <div class="chrono-buttons">
            <button class="btn-chrono btn-start" onclick="btnStart('Meta')">
                ▶ Iniciar
            </button>

            <button class="btn-chrono btn-stop" onclick="registrarVuelta('Meta')">
                ■ Registrar vuelta
            </button>
        </div>
    </div>


    <!-- PITS -->
    <div class="chrono-card c-pits">
        <div class="chrono-label">🔧 PITS → PITS</div>
        <div class="chrono-display" id="chronoPits">00:00:00</div>

        <div class="chrono-buttons">
            <button class="btn-chrono btn-start" onclick="btnStart('PITS')">
                ▶ Iniciar
            </button>

            <button class="btn-chrono btn-stop" onclick="registrarVuelta('PITS')">
                ■ Registrar vuelta
            </button>
        </div>
    </div>


    <!-- CAMBIO PILOTO -->
    <div class="chrono-card c-cambio">
        <div class="chrono-label">👤 CAMBIO DE PILOTO</div>
        <div class="chrono-display" id="chronoCambio">00:00:00</div>

        <div class="chrono-buttons">
            <button class="btn-chrono btn-start" onclick="btnStart('Cambio')">
                ▶ Iniciar
            </button>

            <button class="btn-chrono btn-stop" onclick="registrarVuelta('Cambio')">
                ■ Registrar cambio
            </button>
        </div>
    </div>


    <!-- DAÑOS -->
    <div class="chrono-card c-danos">
        <div class="chrono-label">⚠ DAÑOS</div>
        <div class="chrono-display" id="chronoDanos">00:00:00</div>

        <div class="chrono-buttons">
            <button class="btn-chrono btn-start" onclick="btnStart('Danos')">
                ▶ Iniciar
            </button>

            <button class="btn-chrono btn-stop" onclick="btnStop('Danos')">
                ■ Terminar
            </button>
        </div>
    </div>

</div>

{% endblock %}


{% block body_javascript %}
<script>

let contadorVueltas = 1;

// Timer general de carrera
let timerCarrera = new easytimer.Timer();
let carreraIniciada = false;


// Cronómetros individuales
const cronometros = {
    Meta: {
        timer: new easytimer.Timer(),
        display: '#chronoMeta',
        inicio: null
    },

    PITS: {
        timer: new easytimer.Timer(),
        display: '#chronoPits',
        inicio: null
    },

    Cambio: {
        timer: new easytimer.Timer(),
        display: '#chronoCambio',
        inicio: null
    },

    Danos: {
        timer: new easytimer.Timer(),
        display: '#chronoDanos',
        inicio: null
    }
};



//--------------------------------------
// RELOJ GENERAL DE CARRERA
//--------------------------------------
timerCarrera.addEventListener('secondsUpdated', function () {
    $("#tiempoCarrera").html(
        "⏱ Carrera: " + timerCarrera.getTimeValues().toString()
    );
});



//--------------------------------------
// CONTADOR DE VUELTAS
//--------------------------------------
function actualizarContador() {
    $("#labelContador").html(
        `Vuelta actual: ${contadorVueltas}`
    );
}



//--------------------------------------
// ACTUALIZAR VISUALMENTE CRONÓMETROS
//--------------------------------------
Object.keys(cronometros).forEach(key => {
    const item = cronometros[key];

    item.timer.addEventListener('secondsUpdated', function () {
        $(item.display).html(
            item.timer.getTimeValues().toString()
        );
    });
});



//--------------------------------------
// INICIAR CRONÓMETRO
//--------------------------------------
function btnStart(idChrono) {

    const pilotoActual = $("#pilotoActual").val();

    if (!pilotoActual) {
        alert("Selecciona un piloto actual");
        return;
    }

    const item = cronometros[idChrono];

    if (item.timer.isRunning()) {
        alert("Este cronómetro ya está corriendo");
        return;
    }

    item.inicio = moment().format(
        'YYYY-MM-DD HH:mm:ss'
    );

    item.timer.start();

    // SOLO Meta inicia el reloj general
    if(idChrono === "Meta" && !carreraIniciada){
        timerCarrera.start();
        carreraIniciada = true;
    }

    console.log("Inicio:", idChrono);
}



//--------------------------------------
// REGISTRAR VUELTA
//--------------------------------------
function registrarVuelta(idChrono) {

    const item = cronometros[idChrono];

    const pilotoActual = $("#pilotoActual").val();
    const pilotoSiguiente = $("#pilotoSiguiente").val();

    if (!item.timer.isRunning()) {
        alert("El cronómetro no está iniciado");
        return;
    }

    if (!pilotoActual) {
        alert("Selecciona piloto actual");
        return;
    }

    const fechaFinal = moment().format(
        'YYYY-MM-DD HH:mm:ss'
    );

    const datos = {
        piloto: pilotoActual,
        numeroVuelta: contadorVueltas,
        cronometro: idChrono,
        fecha_inicio: item.inicio,
        fecha_final: fechaFinal
    };

    $.post('/admin/evento/cronometros', datos)
        .done(function(response) {

            alert(
                `Vuelta ${contadorVueltas} registrada correctamente`
            );

            contadorVueltas++;
            actualizarContador();

            item.timer.reset();
            $(item.display).html("00:00:00");

            //--------------------------------
            // Cambio automático de pilotos
            //--------------------------------
            if (
                (idChrono === "Meta" ||
                    idChrono === "PITS" ||
                    idChrono === "Cambio")
                &&
                pilotoSiguiente
            ) {
                $("#pilotoActual").val(pilotoSiguiente);
                $("#pilotoSiguiente").val("");
            }

            item.inicio = moment().format(
                'YYYY-MM-DD HH:mm:ss'
            );

            item.timer.start();
        })
        .fail(function() {
            alert("Error guardando vuelta");
        });
}



//--------------------------------------
// TERMINAR CAMBIO Y DAÑOS
//--------------------------------------
function btnStop(idChrono) {

    const item = cronometros[idChrono];
    const pilotoActual = $("#pilotoActual").val();

    if (!item.timer.isRunning()) {
        alert("El cronómetro no está en marcha");
        return;
    }

    item.timer.stop();

    const fechaFinal = moment().format(
        'YYYY-MM-DD HH:mm:ss'
    );

    const datos = {
        piloto: pilotoActual,
        numeroVuelta: contadorVueltas,
        cronometro: idChrono,
        fecha_inicio: item.inicio,
        fecha_final: fechaFinal
    };

    $.post('/admin/evento/cronometros', datos)
        .done(function(response) {

            alert(`${idChrono} registrado correctamente`);

            item.timer.reset();
            $(item.display).html("00:00:00");
        })
        .fail(function() {
            alert("Error guardando datos");
        });
}



//--------------------------------------
// TERMINAR EVENTO
//--------------------------------------
function terminarEvento() {

    if(confirm("¿Seguro que deseas finalizar el evento?")) {

        //--------------------------------
        // DETENER TODOS LOS CRONÓMETROS
        //--------------------------------
        Object.keys(cronometros).forEach(key => {
            const item = cronometros[key];

            if(item.timer.isRunning()){
                item.timer.stop();
            }

            // destruir tiempo acumulado
            item.timer = new easytimer.Timer();

            // volver a registrar actualización visual
            item.timer.addEventListener('secondsUpdated', function () {
                $(item.display).html(
                    item.timer.getTimeValues().toString()
                );
            });

            // pantalla en cero
            $(item.display).html("00:00:00");

            item.inicio = null;
        });


        //--------------------------------
        // DETENER RELOJ GENERAL
        //--------------------------------
        if(timerCarrera.isRunning()){
            timerCarrera.stop();
        }

        
        //--------------------------------
        // LIMPIAR PILOTOS
        //--------------------------------
        $("#pilotoActual").val("");
        $("#pilotoSiguiente").val("");


        //--------------------------------
        // REINICIAR ESTADO
        //--------------------------------
        carreraIniciada = false;

        alert("Evento finalizado correctamente");
    }
}

</script>
{% endblock %}