{% extends '@EasyAdmin/layout.html.twig' %}

{% block head_javascript %}
{{ parent() }}

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/easytimer.js@4.4.0/dist/easytimer.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/moment@2.29.4/moment.min.js"></script>

<style>
    body {
        background: #0b0b0b;
    }

    .top-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

    .pilot-select {
        width: 100%;
    }

    .contador-box {
        background: #1e1e1e;
        padding: 12px 20px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        gap: 15px;
        color: white;
        font-weight: bold;
    }

    .chrono-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        align-items: start;
    }

    @media(max-width: 768px) {
        .chrono-layout {
            grid-template-columns: 1fr;
        }
    }

    .chrono-card {
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0px 4px 20px rgba(0, 0, 0, 0.3);
    }

    .chrono-label {
        font-size: 16px;
        font-weight: bold;
        text-transform: uppercase;
        margin-bottom: 15px;
        letter-spacing: 1px;
        color: white;
    }

    .chrono-display {
        font-family: 'Courier New', monospace;
        font-size: 42px;
        font-weight: bold;
        text-align: center;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 15px;
    }

    .chrono-buttons {
        display: flex;
        gap: 12px;
    }

    .btn-chrono {
        flex: 1;
        border: none;
        padding: 12px;
        border-radius: 10px;
        font-weight: bold;
        cursor: pointer;
        transition: 0.3s;
    }

    .btn-start:hover {
        transform: scale(1.03);
    }

    /* META */
    .c-meta {
        background: #0F6E56;
    }

    .c-meta .chrono-display {
        background: #0b5643;
        color: white;
    }

    .c-meta .btn-start {
        background: #1fc98a;
        color: white;
    }

    .c-meta .btn-stop {
        background: #094336;
        color: white;
    }

    .c-meta .form-select {
        background: #0b5643;
        color: white;
        border: 1px solid #1fc98a;
    }

    .form-select:focus {
        box-shadow: none;
        color: white;
    }

    .form-select option {
        background: #1e1e1e;
        color: white;
    }

    /* TABLA DE VUELTAS */
    .vueltas-card {
        background: #1a1a1a;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0px 4px 20px rgba(0,0,0,0.3);
    }

    .vueltas-card h3 {
        color: white;
        font-size: 16px;
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 15px;
    }

    .tabla-vueltas {
        width: 100%;
        border-collapse: collapse;
    }

    .tabla-vueltas thead th {
        background: #2a2a2a;
        color: #1fc98a;
        padding: 10px 15px;
        text-align: left;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .tabla-vueltas tbody tr {
        border-bottom: 1px solid #2a2a2a;
        transition: background 0.2s;
    }

    .tabla-vueltas tbody tr:hover {
        background: #222;
    }

    .tabla-vueltas tbody td {
        color: white;
        padding: 10px 15px;
        font-family: 'Courier New', monospace;
        font-size: 15px;
    }

    .tabla-vueltas tbody td:first-child {
        color: #1fc98a;
        font-weight: bold;
    }

    .sin-vueltas {
        color: #555;
        text-align: center;
        padding: 30px;
        font-size: 14px;
    }
</style>
{% endblock %}

{% block main %}

<div class="top-section">

    <div style="width:100%; text-align:center; margin-bottom:25px;">
        <div style="color:white; font-size:18px; font-weight:600; margin-bottom:10px; letter-spacing:1px;">
            TIEMPO TOTAL DE ENTRENAMIENTO
        </div>
        <div id="tiempoCarrera" style="font-family:'Courier New', monospace; font-size:50px; font-weight:300; color:white; letter-spacing:4px;">
            00:00:00
        </div>
    </div>

    <div class="contador-box">
        <span id="labelContador">Vuelta actual: 1</span>
    </div>

    <div class="contador-box">
        <button onclick="terminarEvento()"
            style="background:#ff4d4d; border:none; color:white; padding:10px 20px; border-radius:10px; font-weight:bold; cursor:pointer;">
            Finalizar evento
        </button>
    </div>

</div>

<div class="chrono-layout">

    <!-- META -->
    <div class="chrono-card c-meta">

        <div class="chrono-label">🏁 META → META</div>

        <div class="pilot-select" style="margin-bottom:15px;">
            <label style="color:white; font-weight:bold; margin-bottom:5px; display:block;">
                Piloto
            </label>
            <select class="form-select" id="pilotoMeta">
                <option value="">Seleccionar piloto</option>
                {% for p in pilotos %}
                <option value="{{ p.id }}">{{ p.nombre }}</option>
                {% endfor %}
            </select>
        </div>

        <div class="chrono-display" id="chronoMeta">00:00:00</div>

        <div class="chrono-buttons">
            <button class="btn-chrono btn-start" onclick="btnStart()">
                ▶ Iniciar
            </button>
            <button class="btn-chrono btn-stop" onclick="registrarVuelta()">
                ■ Registrar vuelta
            </button>
        </div>

    </div>

    <!-- TABLA DE VUELTAS -->
    <div class="vueltas-card">
        <h3>📋 Vueltas registradas</h3>
        <table class="tabla-vueltas">
            <thead>
                <tr>
                    <th>Vuelta</th>
                    <th>Piloto</th>
                    <th>Tiempo</th>
                </tr>
            </thead>
            <tbody id="tablaVueltas">
                <tr id="sinVueltas">
                    <td colspan="3" class="sin-vueltas">Aún no hay vueltas registradas</td>
                </tr>
            </tbody>
        </table>
    </div>

</div>

{% endblock %}

{% block body_javascript %}

<script>

    let contadorVueltas = 1;
    let timerCarrera = new easytimer.Timer();
    let carreraIniciada = false;

    const urlCompleta = '/cronometros/api/timer';
    const eventoActivo = '{{ eventoActivo }}';

    const metaTimer = new easytimer.Timer();
    let metaInicio = null;

    // Timer carrera
    timerCarrera.addEventListener('secondsUpdated', () => {
        $("#tiempoCarrera").html(timerCarrera.getTimeValues().toString());
    });

    // Timer META
    metaTimer.addEventListener('secondsUpdated', () => {
        $("#chronoMeta").html(metaTimer.getTimeValues().toString());
    });

    function actualizarContador() {
        $("#labelContador").html(`Vuelta actual: ${contadorVueltas}`);
    }

    function agregarFilaTabla(numeroVuelta, pilotoNombre, tiempo) {
        $("#sinVueltas").remove();
        $("#tablaVueltas").append(`
            <tr>
                <td>${numeroVuelta}</td>
                <td>${pilotoNombre}</td>
                <td>${tiempo}</td>
            </tr>
        `);
    }

    function btnStart() {
        const piloto = $("#pilotoMeta").val();

        if (!piloto) {
            alert("Selecciona un piloto");
            return;
        }

        if (metaTimer.isRunning()) return;

        metaInicio = moment().format('YYYY-MM-DD HH:mm:ss');
        metaTimer.start();

        if (!carreraIniciada) {
            timerCarrera.start();
            carreraIniciada = true;
        }
    }

    function registrarVuelta() {
        const pilotoNombre = $("#pilotoMeta option:selected").text();
        const piloto = $("#pilotoMeta").val();

        if (!metaTimer.isRunning()) {
            alert("El cronómetro no está iniciado");
            return;
        }

        if (!piloto) {
            alert("Selecciona un piloto");
            return;
        }

        const fechaFinal = moment().format('YYYY-MM-DD HH:mm:ss');

        // Calcular tiempo de la vuelta para mostrar en tabla
        const seg = metaTimer.getTimeValues().seconds
            + metaTimer.getTimeValues().minutes * 60
            + metaTimer.getTimeValues().hours * 3600;
        const min = Math.floor(seg / 60);
        const s   = String(seg % 60).padStart(2, '0');
        const tiempoVuelta = `${min}:${s}`;

        const datos = {
            piloto:       piloto,
            numeroVuelta: contadorVueltas,
            cronometro:   'Meta',
            fecha_inicio: metaInicio,
            fecha_final:  fechaFinal,
            eventoActivo: eventoActivo
        };

        $.post(urlCompleta, datos)
            .done(function () {
                agregarFilaTabla(contadorVueltas, piloto, tiempoVuelta);
                contadorVueltas++;
                actualizarContador();

                // Reinicia y sigue corriendo
                metaTimer.reset();
                metaInicio = moment().format('YYYY-MM-DD HH:mm:ss');
                metaTimer.start();
            })
            .fail(() => {
                alert("Error guardando vuelta");
            });
    }

    function terminarEvento() {
    if (confirm("¿Seguro que deseas finalizar el evento?")) {

        const tiempoTotal = timerCarrera.getTimeValues().toString();
        const totalVueltas = contadorVueltas - 1;

        timerCarrera.stop();

        metaTimer.stop();
        metaTimer.reset();
        metaTimer.stop();

        metaInicio = null;
        carreraIniciada = false;
        contadorVueltas = 1;

        $("#chronoMeta").html("00:00:00");
        $("#tiempoCarrera").html(tiempoTotal);

        $("#labelContador").html("Vuelta actual: 1");
        $("#pilotoMeta").val("");

        alert(
            "Evento finalizado\n\n" +
            "Tiempo total: " + tiempoTotal +
            "\nTotal vueltas: " + totalVueltas
        );
    }
}
</script>

{% endblock %}
